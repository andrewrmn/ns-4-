{
    "require": {
        "craftcms/cms": "^4",
        "craftcms/commerce": "^4",
        "craftcms/commerce-paypal-checkout": "^2",
        "craftcms/element-api": "^4.2.0",
        "craftcms/redactor": "^3",
        "enupal/snapshot": "^2",
        "enupal/stripe": "^5",
        "neuroscience/admin-emails": "^1.0",
        "neuroscience/guest-pricing": "^1.0",
        "neuroscience/neuro-rewards": "^1.0",
        "neuroscience/neuroselect": "^1.0",
        "neuroscience/paya": "^1.0",
        "presseddigital/linkit": "^4",
        "surprisehighway/craft-avatax": "^3",
        "verbb/field-manager": "^3",
        "verbb/super-table": "^3",
        "vlucas/phpdotenv": "^3.4.0"
    },
    "require-dev": {
        "yiisoft/yii2-shell": "^2.0.3"
    },
    "autoload": {
        "psr-4": {
            "modules\\pendingusermodule\\": "modules/pendingusermodule/src/",
            "modules\\": "modules/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.0.2"
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true,
            "php-http/discovery": true
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "./plugins/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "composer",
            "url": "https://composer.craftcms.com",
            "canonical": false
        }
    ]
}