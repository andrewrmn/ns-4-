# The environment Craft is currently running in ('dev', 'staging', 'production', etc.)
ENVIRONMENT="dev"


SECURITY_KEY=""
DB_DSN=""
DB_USER="root"
DB_PASSWORD=""
DB_SCHEMA="public"
DB_TABLE_PREFIX=""


# PIR / Neuro Q PDFs — PDFShift only (configure API key). Optional tuning:
# PIR_PDFSHIFT_DISABLE_JAVASCRIPT="true"
# PDFShift API — never commit real keys:
#PDFSHIFT_API_KEY=""
# Watermarked test PDFs, no credits (defaults on if unset). Set false for billed production PDFs.
#PIR_PDFSHIFT_SANDBOX="false"

# Cron “autoship upcoming” patient email (./craft autoship-schedule/auto-ship/upcoming-autoship-email).
# Set false on staging/dev to avoid emailing real customers from a test site. Omit or true for production.
#AUTOSHIP_UPCOMING_EMAIL_ENABLED="false"