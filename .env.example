# The environment Craft is currently running in ('dev', 'staging', 'production', etc.)
ENVIRONMENT="dev"

# The secure key Craft will use for hashing and encrypting data
SECURITY_KEY=""

# The Data Source Name (“DSN”) that tells Craft how to connect to the database
DB_DSN=""

# The database username to connect with
DB_USER="root"

# The database password to connect with
DB_PASSWORD=""

# The database schema that will be used (PostgreSQL only)
DB_SCHEMA="public"

# The prefix that should be added to generated table names (only necessary if multiple things are sharing the same database)
DB_TABLE_PREFIX=""

# PIR / survey PDFs: If PIR_PDF_ENGINE is unset: PDFShift when an API key is set (below), else Chromium
# when a binary is found, else Dompdf. Set PIR_PDF_ENGINE=chromium to force local Chrome despite a PDFShift key.
# Example: PIR_PDF_FETCH_BASE_URL="https://www.neuroscienceinc.com"
#PIR_PDF_FETCH_BASE_URL=""

# PIR_PDF_ENGINE: chromium | pdfshift | wkhtmltopdf | dompdf
#PIR_PDF_ENGINE="chromium"
#PIR_PDF_ENGINE="pdfshift"
#PIR_PDF_ENGINE="dompdf"
#PIR_PDF_ENGINE="wkhtmltopdf"

# PDFShift (https://pdfshift.io) — no local Chrome binary. Uses API v3 with X-API-Key.
# Set one of these on the server (never commit real values). An older key lived in git history
# (plugins/neuroselect before commit 4afe74a); rotate in the PDFShift dashboard if that repo was ever shared.
#PDFSHIFT_API_KEY=""
#PIR_PDFSHIFT_API_KEY=""
# Sandbox defaults ON (watermarked, no credits). Set false when ready for live PDFShift billing.
#PIR_PDFSHIFT_SANDBOX="false"
# Optional Chromium version on PDFShift’s side: "116" or "142"
#PIR_PDFSHIFT_PROCESSOR_VERSION="142"

# Chrome/Chromium binary (optional; auto-detected on Mac/Linux when unset).
#CHROMIUM_BIN="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# Docker / locked-down Linux: often required for headless Chrome
#PIR_CHROMIUM_NO_SANDBOX="1"

# Wait for network/fonts before printing (ms). Increase if PDF looks incomplete.
#CHROMIUM_VIRTUAL_TIME_BUDGET_MS="10000"

# Path to wkhtmltopdf if not on PATH (only when PIR_PDF_ENGINE=wkhtmltopdf).
#WKHTMLTOPDF_BIN="/usr/local/bin/wkhtmltopdf"

# Optional: override PIR print CSS (default: read web/css/pdf9.css from @webroot, else production URL).
#PIR_PDF_STYLESHEET_URL="https://example.com/css/pdf9.css"
