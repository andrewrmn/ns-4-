{
    "require": {
        "craftcms/cms": "3.9.15",
        "craftcms/commerce": "3.4.25",
        "craftcms/commerce-paypal": "3.0.0",
        "craftcms/commerce-paypal-checkout": "1.3.5",
        "craftcms/element-api": "2.8.6.1",
        "craftcms/redactor": "2.10.12",
        "enupal/snapshot": "1.2.9",
        "enupal/stripe": "4.0.10",
        "neuroscience/admin-emails": "1.0.0",
        "neuroscience/guest-pricing": "1.0.0",
        "neuroscience/neuro-rewards": "1.0.0",
        "neuroscience/neuroselect": "1.1.1",
        "neuroscience/paya": "1.0.0",
        "superbig/craft-reports": "1.0.7",
        "surprisehighway/craft-avatax": "2.2.0",
        "verbb/field-manager": "2.2.5",
        "verbb/super-table": "2.7.5.1",
        "vlucas/phpdotenv": "^3.4.0"
    },
    "require-dev": {
        "yiisoft/yii2-shell": "^2.0.3"
    },
    "autoload": {
        "psr-4": {
            "modules\\pendingusermodule\\": "modules/pendingusermodule/src/",
            "modules\\": "modules/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "7.4.21"
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true,
            "php-http/discovery": true
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "./plugins/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "composer",
            "url": "https://composer.craftcms.com",
            "canonical": false
        }
    ]
}